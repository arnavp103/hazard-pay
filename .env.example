# Hazard Pay runs locally with the defaults shown below. Copy this file to
# `.env` only when a developer or cloud-agent environment needs overrides.
# Never commit `.env` or replace these development-only values with secrets.

NODE_ENV=development
LOG_LEVEL=info

# Matches the Postgres service exposed by docker-compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/hazard_pay

PORT=3000
API_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=dev-only-insecure-secret-do-not-use-in-production
TICK_INTERVAL=300000

# Optional: configure this as a cloud-platform secret for live model calls.
# GEMINI_API_KEY=

# Hosted-agent mode keeps work in the provider checkout instead of nesting a
# git worktree. GitHub-backed CLI commands use the REST API, not `gh`.
# HAZARD_PAY_HOSTED_AGENT=true
# GITHUB_REPOSITORY=arnavp103/hazard-pay
# GITHUB_TOKEN=
# GITHUB_API_URL=https://api.github.com
