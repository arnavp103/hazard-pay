{
  "name": "@hazard-pay/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache --max-warnings=0 .",
    "lint:fix": "eslint --cache --fix .",
    "clean": "rm -rf .eslintcache",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hazard-pay/env": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@hazard-pay/config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
